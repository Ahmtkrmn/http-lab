PORT=3000
NODE_ENV=development
# Bu proje `docker compose up` ile TÜM stack'i (app+db+adminer) container'da
# çalıştırmayı asıl (canonical) yöntem olarak benimser (bkz. LEARNING_LOG.md).
# Bu yüzden host adı 'db' (docker-compose.yml'deki servis adı) olmalı, 'localhost' DEĞİL.
# İstisna: `npm run dev` ile uygulamayı container DIŞINDA (native) çalıştırıyorsan
# ve Postgres'e host makineden erişmen gerekiyorsa, host'u 'localhost' yap VE
# docker-compose.yml'deki `db` servisine geçici olarak `ports: - "5432:5432"` ekle
# (bunu commit etme — production'da DB portu dışa açık olmamalı).
DATABASE_URL="postgresql://<kullanici>:<sifre>@db:5432/<veritabani_adi>"
JWT_ACCESS_SECRET=<guclu-bir-gizli-anahtar>
JWT_REFRESH_SECRET=<guclu-bir-gizli-anahtar>

# --- Week 8: Monitoring / Logging / Observability (hepsi opsiyonel) ---
# Log seviyesini elle geçersiz kılar. Tanımlanmazsa: production'da 'info',
# development'ta 'debug', test'te 'silent'. Değerler: trace|debug|info|warn|error|silent
# LOG_LEVEL=debug
#
# /metrics endpoint'i için erişim koruması (bkz. src/middleware/metricsAccessGuard.js).
# METRICS_TOKEN tanımlıysa /metrics'e erişim için `Authorization: Bearer <token>`
# (veya ?token=) ZORUNLU olur — Render gibi PaaS'lerde IP filtresi güvenilmez
# olduğu için önerilen yöntem budur.
# METRICS_TOKEN=<uzun-rastgele-bir-token>
#
# Token yoksa IP allowlist devreye girer: loopback + özel ağlar zaten izinlidir;
# ek olarak izin verilecek halka açık IP'leri (ör. bir dış scraper) virgülle ekle.
# METRICS_ALLOWED_IPS=203.0.113.10,203.0.113.11
