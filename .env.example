PORT=3000
NODE_ENV=development
# Bu proje `docker compose up` ile TÜM stack'i (app+db+adminer) container'da
# çalıştırmayı asıl (canonical) yöntem olarak benimser (bkz. LEARNING_LOG.md).
# Bu yüzden host adı 'db' (docker-compose.yml'deki servis adı) olmalı, 'localhost' DEĞİL.
# İstisna: `npm run dev` ile uygulamayı container DIŞINDA (native) çalıştırıyorsan
# ve Postgres'e host makineden erişmen gerekiyorsa, host'u 'localhost' yap VE
# docker-compose.yml'deki `db` servisine geçici olarak `ports: - "5432:5432"` ekle
# (bunu commit etme — production'da DB portu dışa açık olmamalı).
DATABASE_URL="postgresql://<kullanici>:<sifre>@db:5432/<veritabani_adi>"
JWT_ACCESS_SECRET=<guclu-bir-gizli-anahtar>
JWT_REFRESH_SECRET=<guclu-bir-gizli-anahtar>
