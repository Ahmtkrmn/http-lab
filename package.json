{
  "name": "http-lab",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "db:migrate:test": "dotenv -e .env.test -- npx prisma migrate deploy",
    "pretest": "npm run db:migrate:test",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --runInBand tests/unit",
    "test:integration": "jest --runInBand --forceExit tests/integration",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "pretest:coverage": "npm run db:migrate:test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "jest": {
    "setupFiles": [
      "<rootDir>/tests/jest.setup.js"
    ],
    "testEnvironment": "node",
    "testTimeout": 15000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 70,
        "functions": 80,
        "lines": 80
      }
    }
  }
}
