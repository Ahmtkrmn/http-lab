# monitoring/.env.monitoring.example
# Bu dosyayı `.env.monitoring` olarak kopyala ve değerleri doldur.
# `.env.monitoring` .gitignore'da olmalı — GERÇEK sırlar commit edilmez!

# Yoklanacak hedef: canlı http-lab'in host:port'u (Render HTTPS -> :443).
SCRAPE_TARGET=http-lab.onrender.com:443

# Render'da ayarladığın METRICS_TOKEN ile AYNI değer olmalı.
# (Render → http-lab servisi → Environment → Add: METRICS_TOKEN)
METRICS_TOKEN=

# --- Grafana Cloud remote_write kimlik bilgileri ---
# Grafana Cloud → sol menü "Connections" veya "Home" → Prometheus data source
# detaylarında bulunur.
#
# Remote write endpoint URL'i (…/api/prom/push ile biter):
GRAFANA_CLOUD_PROM_URL=

# Prometheus "Username / Instance ID" (bir sayı):
GRAFANA_CLOUD_USER=

# API token (Grafana Cloud → Access Policies / API Keys; "metrics:write"
# yetkili bir token oluştur):
GRAFANA_CLOUD_API_KEY=
