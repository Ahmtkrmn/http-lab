generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  items     Item[]
  createdAt DateTime @default(now())
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  name String

  password     String   // Bcrypt ile hashlenmiş şifre gelecek, asla düz metin (plain text) değil!
  role         Role     @default(VIEWER) // Varsayılan olarak herkes en düşük yetkiyle başlar
  refreshToken String?  // JWT Refresh Token'ı db'de saklayacağız (Rotation için)

  items Item[]
  createdAt DateTime @default(now())
}

model Item {
  id         Int      @id @default(autoincrement())
  name       String
  price      Float
  description String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int

  user User?    @relation(fields:[userId],references:[id])
  userId Int?
}