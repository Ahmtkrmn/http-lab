# Bu dosyayı .env.local olarak kopyala (cp .env.example .env.local).
# .env.local gitignore'ludur (Vite şablonundaki *.local kuralı) — makineye
# özel ayarlar oraya yazılır, bu örnek dosya ise repoda kalır.
#
# VITE_ öneki ZORUNLU: Vite yalnızca bu önekli değişkenleri bundle'a açar.
# Buraya asla secret yazma — değerler tarayıcıya giden JS'e gömülür.

# Backend API adresi (dev'de docker compose'daki app servisi):
VITE_API_URL=http://localhost:3000

# Production'da (Vercel/Netlify) bu değişkeni panelden Render URL'i olarak ayarla:
# VITE_API_URL=https://http-lab.onrender.com
