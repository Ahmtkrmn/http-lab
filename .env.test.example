# Bu dosyayı .env.test olarak kopyalayıp gerçek bir test veritabanına
# işaret edecek şekilde doldurun. tests/jest.setup.js bu dosyayı otomatik
# yükler (npm test / npm run test:coverage çalıştırıldığında).
#
# ÖNEMLİ: .env.test, geliştirme veritabanınızdan (.env) AYRI bir
# veritabanına işaret etmelidir; testler her çalıştırmada tabloları
# TAMAMEN TEMİZLER (bkz. tests/testUtils/resetDb.js).
PORT=3001
NODE_ENV=test
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/http_lab_test"
JWT_ACCESS_SECRET=test_access_secret
JWT_REFRESH_SECRET=test_refresh_secret
